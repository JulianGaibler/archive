---
import Layout from '../layouts/Layout.astro'
import {
  LoginDocument,
  SignupAllowedDocument,
  type LoginMutation,
  type LoginMutationVariables,
  type SignupAllowedQuery,
} from '../generated/graphql'
import LoginForm from './login/_login-form.svelte'

const ssrClient = Astro.locals.gqlClient

let error = ''

if (Astro.locals.me.signedIn) {
  return Astro.redirect('/')
}

// Get redirect URL from query params and validate it's safe
const requestedRedirect = new URL(Astro.request.url).searchParams.get(
  'redirect',
)
let redirectUrl = '/'
// Only allow redirects to the same origin and not to external sites
if (
  requestedRedirect &&
  requestedRedirect.startsWith('/') &&
  !requestedRedirect.startsWith('//')
) {
  redirectUrl = requestedRedirect
}

// Handle POST request (form submission)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData()
    const username = formData.get('username')?.toString()
    const password = formData.get('password')?.toString()
    // Get redirect from form, validate again
    const formRedirect = formData.get('redirect')?.toString()
    let safeRedirect = '/'
    if (
      formRedirect &&
      formRedirect.startsWith('/') &&
      !formRedirect.startsWith('//')
    ) {
      safeRedirect = formRedirect
    }

    if (!username || !password) {
      error = 'Username and password are required'
    } else {
      const result = await ssrClient.request<
        LoginMutation,
        LoginMutationVariables
      >(LoginDocument, {
        username,
        password,
      })

      if (result.login.requiresTotp) {
        // Set pending token as a short-lived httpOnly cookie
        const isProduction = import.meta.env.PROD
        Astro.cookies.set('pending-totp', result.login.pendingToken!, {
          httpOnly: true,
          secure: isProduction,
          maxAge: 300, // 5 minutes
          sameSite: 'lax',
          path: '/login',
        })
        const verifyUrl = `/login/verify${safeRedirect !== '/' ? `?redirect=${encodeURIComponent(safeRedirect)}` : ''}`
        return Astro.redirect(verifyUrl)
      }

      if (result.login.success) {
        return Astro.redirect(safeRedirect)
      } else {
        error = 'Invalid username or password'
      }
    }
  } catch (err) {
    console.error('Login error:', err)
    error = 'Login failed. Please try again.'
  }
}

let signupAllowed = false
try {
  const result = await ssrClient.request<SignupAllowedQuery>(
    SignupAllowedDocument,
  )
  signupAllowed = result.signupAllowed
} catch {
  // If query fails, just don't show signup link
}

const slogan = [
  "Da, wo d'Memes zum Sterbn hi'geh",
  'Where memes go to die',
  'Là où les mèmes vont mourir',
  'Ubi memes morituri eunt',
  'Donde los memes van a morir',
  'ミームが死にに行く場所',
  "Where th' memes be walkin' the plank!",
  "Dört, wo d'Memes sterbe gönd",
].sort(() => Math.random() - 0.5)[0]
---

<Layout title="Login" flexCenter>
  <div class="background">
    <div class="brand">
      <h1 class="tint--type-display-sans-3">Archive</h1>
      <p class="tint--type-title-serif-3">{slogan}</p>
    </div>
    <div class="card tint--card">
      <LoginForm
        client:load
        {redirectUrl}
        {signupAllowed}
        initialError={error || undefined}
      />
    </div>
  </div>
</Layout>

<style lang="sass">
  .background
    background: var(--tint-text-accent)
    align-self: stretch
    justify-self: stretch
    display: flex
    align-items: center
    justify-content: center
    flex: 1
    gap: 80px
    padding: tint.$size-16
    @media (max-width: tint.$breakpoint-md)
      flex-direction: column
      justify-content: flex-start
      gap: tint.$size-32
  .brand
    color: white
    padding: tint.$size-32
  .card
    padding: tint.$size-32
    width: 100%
    box-sizing: border-box
    max-width: 400px
    display: flex
    flex-direction: column
    gap: tint.$size-16
</style>
