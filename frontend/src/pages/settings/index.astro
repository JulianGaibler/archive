---
import Layout from '@src/layouts/Layout.astro'
import SettingsCard from '@src/components/SettingsCard.astro'
import ChangePassword from './_change-password.svelte'
import ChangeName from './_change-name.svelte'
import ChangeProfilePicture from './_change-profile-picture.svelte'
import ManageSessions from './_manage-sessions.svelte'
import TelegramConnection from './_telegram-connection.svelte'
import CaptionPreferences from './_caption-preferences.svelte'
import TwoFactorAuth from './_two-factor-auth.svelte'
import PasskeyManagement from './_passkey-management.svelte'
import ErrorPage from '@src/components/ErrorPage.astro'

import { getSdk } from '@src/generated/graphql'
import { handleError, hasAuthenticationError } from '@src/utils/page-errors'

const ssrClient = Astro.locals.gqlClient

const sdk = getSdk(ssrClient)

let result: Awaited<ReturnType<typeof sdk.settings>> | null = null
let error: ReturnType<typeof handleError> | null = null

try {
  result = await sdk.settings()
  error = hasAuthenticationError(result, Astro.response)
} catch (graphqlError: unknown) {
  error = handleError(500, Astro.response, graphqlError)
}
---

{
  error ? (
    <ErrorPage error={error} />
  ) : (
    <Layout title="Account settings">
      <div class="tint--tinted head">
        <div class="shrinkwrap">
          <h2 class="tint--type-title-serif-2">Account settings</h2>
        </div>
      </div>
      <div>
        <div class="shrinkwrap">
          <div class="sections">
            <section class="section">
              <h2 class="tint--type-title-serif-3">Your profile</h2>
              <div class="cards">
                <SettingsCard heading="Profile picture">
                  <ChangeProfilePicture client:load user={result!.data.me} />
                </SettingsCard>
                <SettingsCard heading="Your name">
                  <ChangeName client:load user={result!.data.me} />
                </SettingsCard>
              </div>
            </section>

            <section class="section">
              <h2 class="tint--type-title-serif-3">Preferences</h2>
              <div class="cards">
                <SettingsCard
                  heading="Captions"
                  description="Settings are saved to this device only."
                >
                  <CaptionPreferences client:load />
                </SettingsCard>
                <SettingsCard
                  heading="Telegram"
                  description="Connect your Archive account with Telegram to enable posting directly from the arnoldbot."
                >
                  <TelegramConnection client:load user={result!.data.me} />
                </SettingsCard>
              </div>
            </section>

            <section class="section">
              <h2 class="tint--type-title-serif-3">Security</h2>
              <div class="cards">
                <SettingsCard heading="Password">
                  <ChangePassword
                    client:load
                    totpEnabled={result!.data.me.totpStatus?.enabled ?? false}
                  />
                </SettingsCard>
                <SettingsCard heading="Two-factor authentication">
                  <TwoFactorAuth
                    client:load
                    totpStatus={result!.data.me.totpStatus ?? null}
                  />
                </SettingsCard>
                <SettingsCard
                  heading="Passkeys"
                  description="Sign in without a password using your device's biometrics or security key."
                >
                  <PasskeyManagement
                    client:load
                    passkeys={result!.data.me.passkeys ?? []}
                    totpEnabled={result!.data.me.totpStatus?.enabled ?? false}
                  />
                </SettingsCard>
                <SettingsCard
                  heading="Sessions"
                  description="View and manage your active sessions."
                >
                  <ManageSessions
                    client:load
                    sessions={result!.data.userSessions}
                  />
                </SettingsCard>
              </div>
            </section>
          </div>
        </div>
      </div>
    </Layout>
  )
}

<style lang="sass">
  .head
    background: var(--tint-bg)
    padding-block: tint.$size-24
    margin-block-end: tint.$size-16

  .sections
    display: flex
    flex-direction: column
    gap: tint.$size-32
    margin: 0 auto
    max-width: 768px
    @media (max-width: 768px)
      max-width: 384px

    h2
      margin-block-end: tint.$size-16
      color: var(--tint-text-secondary)

  .cards
    display: grid
    grid-template-columns: repeat(2, 1fr)
    gap: tint.$size-16
    @media (max-width: 768px)
      grid-template-columns: 1fr
</style>
